{
  "id": null,
  "uid": "rag-overview-nosudo",
  "title": "RAG 压测与资源监控总览",
  "tags": ["rag", "nosudo", "benchmark", "中文"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "time": {"from": "now-6h", "to": "now"},
  "templating": {"list": []},
  "annotations": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "LM Studio API 状态",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [{"expr": "lmstudio_up", "legendFormat": "接口状态"}],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "离线", "color": "red"}, "1": {"text": "正常", "color": "green"}}}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}
        },
        "overrides": []
      },
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "lms 推理进程数",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [{"expr": "lms_process_count", "legendFormat": "lms"}],
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}
        },
        "overrides": []
      },
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "llmster 工作进程数",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "targets": [{"expr": "llmster_process_count", "legendFormat": "llmster"}],
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}
        },
        "overrides": []
      },
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "主机内存使用率",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "(host_memory_used_bytes / host_memory_total_bytes) * 100", "legendFormat": "内存"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "red", "value": 85}]}
        },
        "overrides": []
      },
      "options": {"showThresholdLabels": false, "showThresholdMarkers": true, "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "距上次压测已过",
      "gridPos": {"h": 4, "w": 3, "x": 18, "y": 0},
      "targets": [{"expr": "time() - rag_benchmark_last_run_timestamp_seconds", "legendFormat": "距今"}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "长上下文目标字符数",
      "gridPos": {"h": 4, "w": 3, "x": 21, "y": 0},
      "targets": [{"expr": "rag_benchmark_long_context_target_chars", "legendFormat": "目标字符数"}],
      "fieldConfig": {"defaults": {"unit": "none"}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "大上下文成功率",
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 4},
      "targets": [{"expr": "rag_benchmark_success_rate_percent{scenario=\"长上下文压测\"}", "legendFormat": "{{model}}"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 95}, {"color": "green", "value": 99}]}
        },
        "overrides": []
      },
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true}
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "大上下文平均返回时间",
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 4},
      "targets": [{"expr": "rag_benchmark_latency_avg_seconds{scenario=\"长上下文压测\"}", "legendFormat": "{{model}}"}],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 20}, {"color": "red", "value": 40}]}
        },
        "overrides": []
      },
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true}
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "大上下文 P95 返回时间",
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 4},
      "targets": [{"expr": "rag_benchmark_latency_p95_seconds{scenario=\"长上下文压测\"}", "legendFormat": "{{model}}"}],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 25}, {"color": "red", "value": 45}]}
        },
        "overrides": []
      },
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true}
    },
    {
      "id": 10,
      "type": "bargauge",
      "title": "大上下文输出吞吐",
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 11},
      "targets": [{"expr": "rag_benchmark_output_tokens_per_second_cluster{scenario=\"长上下文压测\"}", "legendFormat": "{{model}}"}],
      "fieldConfig": {"defaults": {"unit": "ops", "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 20}, {"color": "green", "value": 40}]}}, "overrides": []},
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true}
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "大上下文请求吞吐",
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 11},
      "targets": [{"expr": "rag_benchmark_requests_per_second{scenario=\"长上下文压测\"}", "legendFormat": "{{model}}"}],
      "fieldConfig": {"defaults": {"unit": "reqps", "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 0.2}, {"color": "green", "value": 0.5}]}}, "overrides": []},
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true}
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "大上下文平均输入 Token",
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 11},
      "targets": [{"expr": "rag_benchmark_prompt_tokens_avg{scenario=\"长上下文压测\"}", "legendFormat": "{{model}}"}],
      "fieldConfig": {"defaults": {"unit": "none"}, "overrides": []},
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true}
    },
    {
      "id": 13,
      "type": "bargauge",
      "title": "大上下文平均输出 Token",
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 18},
      "targets": [{"expr": "rag_benchmark_completion_tokens_avg{scenario=\"长上下文压测\"}", "legendFormat": "{{model}}"}],
      "fieldConfig": {"defaults": {"unit": "none"}, "overrides": []},
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true}
    },
    {
      "id": 14,
      "type": "bargauge",
      "title": "大上下文平均总 Token",
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 18},
      "targets": [{"expr": "rag_benchmark_total_tokens_avg{scenario=\"长上下文压测\"}", "legendFormat": "{{model}}"}],
      "fieldConfig": {"defaults": {"unit": "none"}, "overrides": []},
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true}
    },
    {
      "id": 15,
      "type": "bargauge",
      "title": "基线 vs 大上下文平均返回时间",
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 18},
      "targets": [{"expr": "rag_benchmark_latency_avg_seconds", "legendFormat": "{{model}} / {{scenario}}"}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true}
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "GPU 利用率趋势",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 25},
      "targets": [{"expr": "rag_gpu_utilization_percent", "legendFormat": "GPU {{gpu}}"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "GPU 显存占用趋势",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 25},
      "targets": [{"expr": "rag_gpu_memory_used_mib", "legendFormat": "GPU {{gpu}}"}],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 8}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "GPU 温度趋势",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 33},
      "targets": [{"expr": "rag_gpu_temperature_celsius", "legendFormat": "GPU {{gpu}}"}],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 75}, {"color": "red", "value": 85}]}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "GPU 功耗趋势",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 33},
      "targets": [{"expr": "rag_gpu_power_watts", "legendFormat": "GPU {{gpu}}"}],
      "fieldConfig": {"defaults": {"unit": "watt"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    }
  ]
}
