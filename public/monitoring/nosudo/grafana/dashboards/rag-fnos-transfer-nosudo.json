{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "FNOS TCP 可达性",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "max(rag_fnos_tcp_up)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value"
      }
    },
    {
      "type": "timeseries",
      "title": "FNOS TCP 延迟（秒）",
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rag_fnos_tcp_latency_seconds",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "网络带宽（宿主/容器，MiB/s）",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (scope) (rate(rag_network_rx_bytes_total{iface!~\"lo|docker0|veth.*\"}[2m])) / 1024 / 1024",
          "legendFormat": "{{scope}} 下行",
          "refId": "A"
        },
        {
          "expr": "sum by (scope) (rate(rag_network_tx_bytes_total{iface!~\"lo|docker0|veth.*\"}[2m])) / 1024 / 1024",
          "legendFormat": "{{scope}} 上行",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "最新备份体积（按范围，GiB）",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rag_backup_latest_size_bytes / 1024 / 1024 / 1024",
          "legendFormat": "{{scope}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "备份新鲜度（小时）",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "(time() - rag_backup_latest_timestamp_seconds) / 3600",
          "legendFormat": "{{scope}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "rag",
    "fnos",
    "transfer",
    "tailscale"
  ],
