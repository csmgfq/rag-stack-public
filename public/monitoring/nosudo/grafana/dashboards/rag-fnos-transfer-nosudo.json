{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "FNOS TCP Reachability",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "max(rag_fnos_tcp_up)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "orientation": "auto", "colorMode": "value"}
    },
    {
      "type": "timeseries",
      "title": "FNOS TCP Latency (s)",
      "gridPos": {"h": 8, "w": 18, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "rag_fnos_tcp_latency_seconds", "legendFormat": "{{target}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Network Bandwidth Host/Container (MiB/s)",
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (scope) (rate(rag_network_rx_bytes_total{iface=~\"tailscale0|eth0\"}[2m])) / 1024 / 1024", "legendFormat": "{{scope}} rx", "refId": "A"},
        {"expr": "sum by (scope) (rate(rag_network_tx_bytes_total{iface=~\"tailscale0|eth0\"}[2m])) / 1024 / 1024", "legendFormat": "{{scope}} tx", "refId": "B"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Latest Backup Size by Scope (GiB)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 17},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "rag_backup_latest_size_bytes / 1024 / 1024 / 1024", "legendFormat": "{{scope}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Backup Freshness (hours)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 17},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "(time() - rag_backup_latest_timestamp_seconds) / 3600", "legendFormat": "{{scope}}", "refId": "A"}]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "style": "dark",
