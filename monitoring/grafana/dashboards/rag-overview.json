{
  "id": null,
  "uid": "rag-overview",
  "title": "RAG Server Overview",
  "tags": [
    "rag",
    "gpu",
    "lmstudio"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU Usage %",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage %",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "GPU Utilization %",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "GPU {{gpu}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "GPU Memory Used (MiB)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED",
          "legendFormat": "GPU {{gpu}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "llmster Process Count",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "namedprocess_namegroup_num_procs{groupname=\"llmster\"}",
          "legendFormat": "llmster"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network Receive (MB/s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum by(instance) (rate(node_network_receive_bytes_total{device!~\"lo\"}[2m])) / 1024 / 1024",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Runtime Router Up",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "rag_runtime_router_up",
          "legendFormat": "Runtime Router Up"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "ReAct Agent Up",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 24
      },
      "targets": [
        {
          "expr": "rag_react_agent_up",
          "legendFormat": "ReAct Agent Up"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "vLLM Gateway Up",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 24
      },
      "targets": [
        {
          "expr": "rag_vllm_gateway_up",
          "legendFormat": "vLLM Gateway Up"
        }
      ],
      "options": {
